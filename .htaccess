# Enable RewriteEngine
RewriteEngine On

# Set the base directory
RewriteBase /SYSARCH/

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Handle pages in the pages/ directory
# If user accesses /admin_dashboard, rewrite to /pages/admin_dashboard.php
RewriteRule ^admin_dashboard/?$ pages/admin_dashboard.php [L]
RewriteRule ^manage_students/?$ pages/manage_students.php [L]
RewriteRule ^edit_student/?$ pages/edit_student.php [L]
RewriteRule ^edit_profile/?$ pages/edit_profile.php [L]
RewriteRule ^userdb/?$ pages/userdb.php [L]
RewriteRule ^delete_student/?$ pages/delete_student.php [L]
RewriteRule ^logout/?$ pages/logout.php [L]

# Internally rewrite PHP files at root to pages/ directory
RewriteCond %{REQUEST_URI} !^/SYSARCH/pages/
RewriteRule ^([a-zA-Z0-9_-]+)\.php$ pages/$1.php [L]
